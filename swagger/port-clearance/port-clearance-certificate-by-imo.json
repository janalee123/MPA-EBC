    "info":  {
                 "title":  "Port Clearance Certificates",
                 "description":  "Port Clearance Cert by IMO Number \n/imonumber/{imonumber}   GET\n\nPort Clearance Cert by CallSign \n/callsign/{callsign}     GET\n\nPort Clearance Cert by Vessel Name\n/vesselname/{vesselname}    GET",
                 "version":  "1.0.0"
             },
    "servers":  [
                    {
                        "url":  "https://oceans-x.mpa.gov.sg/api/v1/vessel/portclearance/1.0.0"
                    },
                    {
