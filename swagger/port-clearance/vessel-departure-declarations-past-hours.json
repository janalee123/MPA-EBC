    "info":  {
                 "title":  "Vessel Departure Declarations",
                 "description":  "Vessel Departure Declaration for Past ‘N’ Hours  \n/pastNhours   GET\n\nVessel Departure Declaration by Vessel Name  \n/vesselname/{vesselname}   GET\n\nVessel Departure Declaration by CallSign \n/callsign/{callsign}   GET\n\n\nVessel Departure Declaration by IMO Number \n/imonumber/{imonumber}   GET\n\n\nVessel Departure Declaration by Date \n/bydate   GET\n",
                 "version":  "1.0.0"
             },
    "servers":  [
                    {
