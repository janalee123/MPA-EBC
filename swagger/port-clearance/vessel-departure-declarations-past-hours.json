                                                                            },
                                                                    "415":  {
                                                                                "description":  "Unsupported Media Type:Please try with valid MIME Types"
                                                                            },
                                                                    "500":  {
                                                                                "description":  "Something went wrong on the gateway / Internal Server Error:Please try after sometime"
                                                                            },
                                                                    "501":  {
                                                                                "description":  "Not Implemented"
                                                                            },
                                                                    "502":  {
